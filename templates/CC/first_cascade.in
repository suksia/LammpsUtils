# ----- initialization ----- #

units metal
atom_style atomic
boundary p p p

read_data config.in

pair_style ?pair_style?
pair_coeff * * ?potential? ?elements?

neighbor ?skin? bin
neigh_modify every 1 delay 0 check yes

# ----- define regions and groups ----- #

variable bath_th equal ?lattice_const?*?bath?

region cascade block $(xlo+v_bath_th) $(xhi-v_bath_th) $(ylo+v_bath_th) $(yhi-v_bath_th) $(zlo+v_bath_th) $(zhi-v_bath_th)
group cascade region cascade

group bath subtract all cascade

write_dump bath custom bath.dump id type x y z

region pka sphere ?pka_pos? 0.5
group pka region pka

write_dump pka custom pka_?cascade_idx?.dump id type x y z

# ----- equilibrate ----- #

thermo_style custom step pe
thermo 1

min_style cg
minimize ?etol? ?ftol? ?maxiter? ?maxeval?

reset_timestep 0

thermo_style custom step pe press vol temp
thermo 25

timestep ?timestep?

fix equil all npt temp ?temp? ?temp? ?Tdamp? iso 0.0 0.0 ?Pdamp?

velocity all create ?temp? ?vel_seed?

run ?equil?

unfix equil

reset_timestep 0
write_dump all custom reference.dump id type x y z

# ----- cascade ----- #

timestep 0.0001

thermo_style custom step time dt press temp
thermo 1

compute 1 all pe/atom
variable hot atom ?hot_group?

group hot dynamic all var hot every ?snapshot?
dump 1 hot custom ?snapshot? cascade.dump id type x y z

fix nve all nve
fix bath bath langevin ?temp? ?temp? ?Tdamp? ?lang_seed?

fix adapt_dt all dt/reset 1 ?mindt? ?maxdt? ?maxdr? units box

velocity pka set ?pka_vel?

run ?nsteps?

undump 1
unfix nve
unfix bath
unfix adapt_dt

write_restart cascade.restart

reset_timestep 0
write_dump all custom final.dump id type x y z

# ----- quench reference and post-cascade cells ----- #

thermo_style custom step pe press
thermo 1

read_dump reference.dump 0 id type x y z replace yes

minimize ?etol? ?ftol? ?maxiter? ?maxeval?

reset_timestep 0
run 0
write_dump all custom quench.dump id type x y z c_1

read_dump final.dump 0 id type x y z replace yes

minimize ?etol? ?ftol? ?maxiter? ?maxeval?

reset_timestep 1
run 0
write_dump all custom quench.dump id type x y z c_1 modify append yes

group pka delete
group hot delete