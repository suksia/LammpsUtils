# ----- initialization ----- #

read_restart cascade.restart

pair_style ?pair_style?
pair_coeff * * ?potential? ?elements?

neighbor ?skin? bin
neigh_modify every 1 delay 0 check yes

# ----- define PKA group ----- #

group PKA delete

region pka sphere ?pka_pos? 0.5
group pka region pka

write_dump pka custom pka_?cascade_idx?.dump id type x y z

# ----- cascade ----- #

timestep 0.0001

log cascade_?cascade_idx?.log
thermo_style custom step time dt press temp
thermo 1

compute 1 all pe/atom
variable hot atom ?hot_group?

group hot dynamic all var hot every ?snapshot?
dump 1 hot custom ?snapshot? cascade.dump id type x y z modify append yes
neigh_modify

fix nve all nve
fix bath bath langevin ?temp? ?temp? ?Tdamp? ?lang_seed?

fix adapt_dt all dt/reset 1 ?mindt? ?maxdt? ?maxdr? units box

velocity pka set ?pka_vel?

run ?nsteps?

undump 1
unfix nve
unfix bath
unfix adapt_dt

reset_timestep 0
write_dump all custom cascade_?cascade_idx?.dump id type x y z

write_restart cascade.restart

# ----- quench reference and post-cascade cells ----- #

read_dump reference.dump 0 id type x y z replace yes

minimize ?etol? ?ftol? ?maxiter? ?maxeval?

reset_timestep 0
write_dump all custom quench.dump id type x y z c_1

read_dump final.dump 0 id type x y z replace yes

minimize ?etol? ?ftol? ?maxiter? ?maxeval?

reset_timestep 1
write_dump all custom quench.dump id type x y z c_1 modify append yes