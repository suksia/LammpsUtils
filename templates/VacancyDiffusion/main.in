units metal
atom_style atomic
boundary p  p  p

lattice ?lattice? ?lattice_const?
region lat block 0 ?size_x? 0 ?size_y? 0 ?size_z?
create_box 1 lat
create_atoms 1 box

pair_style ?pair_style?
pair_coeff * * ?potential? ?element?

neighbor ?skin? bin
neigh_modify delay 0 check yes

write_dump all custom init.dump id type x y z
write_dump all custom minimize.dump id type x y z

include ?pd_fn?

log init.log
thermo_style custom step e_pot temp
thermo 1

min_style cg
minimize 1e-10 1e-10 1000 100000

write_dump all custom init.dump id type x y z modify append yes

neigh_modify delay 10

include equil.in
include diffusion.in
include minimize.in