units metal
atom_style atomic
boundary p  p  p

read_data defective.struct

pair_style ?pair_style?
pair_coeff * * ?potential? ?elements?

neighbor ?skin? bin
neigh_modify every 1 delay 0 check yes

fix int all nve
fix mc all atom/swap 1 ?mc_attempts? ?mc_seed? ?temp? types 1 2

variable acc_ratio equal "ternary(f_mc[1] > 0, f_mc[2]/f_mc[1], 0.0)"

thermo_style custom step pe press enthalpy v_acc_ratio
thermo 1

min_style cg

variable i loop ?mc_cycles?
variable s equal v_i % ?snapshot?

label loop

if "${s}==0" then "write_dump all custom mc.dump id type x y z modify append yes"

log mc.log append
run 1 post no

log min.log append
minimize ?etol? ?ftol? ?maxiter? ?maxeval?

fix mc all atom/swap 1 ?mc_attempts? ?mc_seed? ?temp? types 1 2

next i
jump SELF loop

write_dump all custom defective.dump id type x y z

thermo_style custom step pe press vol enthalpy

log energies.log append
run 0