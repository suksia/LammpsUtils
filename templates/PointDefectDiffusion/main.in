units metal
atom_style atomic
boundary p  p  p

read_data struct.in

pair_style ?pair_style?
pair_coeff * * ?potential? ?element?

neighbor ?skin? bin
neigh_modify delay 0 check yes

write_dump all custom init.dump id type x y z
write_dump all custom diffusion.dump id type x y z
write_dump all custom quench.dump id type x y z

log init.log
thermo_style custom step pe
thermo 1

min_style cg
minimize 1e-10 1e-10 1000 100000

reset_timestep 1
write_dump all custom init.dump id type x y z modify append yes

neigh_modify delay 10

include equil.in
include diffusion.in
include quench.in