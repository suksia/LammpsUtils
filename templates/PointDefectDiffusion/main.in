units metal
atom_style atomic
boundary p  p  p

read_data config.struct

pair_style ?pair_style?
pair_coeff * * ?potential? ?element?

neighbor ?skin? bin
neigh_modify every 1 delay 0 check yes

# -------- Energy minimize -------- #

log init.log
thermo_style custom step pe press vol
thermo 1

min_style cg
minimize ?etol? ?ftol? ?maxiter? ?maxeval?

# ---------- Equilibrate ---------- #

reset_timestep 0

write_dump all custom init.dump id type x y z
write_dump all custom diffusion.dump id type x y z
write_dump all custom quench.dump id type x y z

neigh_modify delay 10

timestep ?timestep?
velocity all create ?temp? ?seed?

fix 1 nve
fix 2 all langevin ?temp? ?temp? 100
fix 3 all momentum 100 linear 1 1 1

log equil.log
thermo_style custom step etotal temp press
thermo 1000

run ?equil?

# --=-------- Diffusion --=-------- #

reset_timestep 0

compute msdvar all msd

dump 1 all custom ?snapshot? diffusion.dump id type x y z
dump_modify 1 append yes

log diffusion.log
thermo_style custom step c_msdvar[4]
thermo ?snapshot?

run ?diffusion?
 
# ------------- Quench ------------ #

unfix 1
unfix 2
undump 1

log quench.log
thermo_style custom step pe
thermo 1

neigh_modify delay 0 check yes

label loop

variable tstep_idx loop ?num_snapshots?
variable tstep equal ${tstep_idx}*?snapshot?

print "Timestep idx: ${tstep_idx}"
print "Timestep: ${tstep}"

read_dump diffusion.dump ${tstep} x y z replace yes

reset_timestep 0

minimize ?etol? ?ftol? ?maxiter? ?maxeval?

reset_timestep ${tstep}
write_dump all custom quench.dump id type x y z modify append yes

next tstep_idx

jump SELF loop